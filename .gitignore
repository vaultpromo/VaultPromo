# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep example, ignore secrets
.env
.env.local
.env.development
.env.production
# allow the example file
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Lambda FFmpeg binary — large file, not needed in repo
# Download separately: https://johnvansickle.com/ffmpeg/
lambda/audio-worker/bin/
lambda/audio-worker/dist/
lambda/audio-worker/node_modules/
lambda/audio-worker/worker.zip
