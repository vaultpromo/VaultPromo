{
  "name": "fatdrop-audio-worker",
  "version": "1.0.0",
  "description": "Lambda container worker: fetches WAV from R2, transcodes to 128kbps MP3 with FFmpeg, uploads preview to R2, calls webhook.",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1084.0",
    "@aws-sdk/s3-request-presigner": "3.1084.0",
    "fluent-ffmpeg": "2.1.3",
    "pg": "8.16.0",
    "pg-boss": "12.25.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "2.1.27",
    "@types/node": "^20",
    "@types/pg": "^8",
    "typescript": "^5"
  }
}
